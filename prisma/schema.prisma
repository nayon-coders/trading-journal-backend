generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  accounts  Account[]
  setups    Setup[]
}

model Setup {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  rules       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  checklist   Json?
  user        User     @relation(fields: [userId], references: [id])
  trades      Trade[]
}

model Account {
  id              String   @id @default(uuid())
  userId          String
  accountName     String
  brokerName      String?
  startingBalance Float
  currentBalance  Float
  accountType     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  currency        String   @default("USD")
  environment     String   @default("Live")
  user            User     @relation(fields: [userId], references: [id])
  trades          Trade[]
}

model Trade {
  id                  String   @id @default(uuid())
  userId              String
  accountId           String
  tradeDate           DateTime
  tradeTime           String
  pair                String
  direction           String
  bias                String?
  setup               String?
  setupId             String?
  confidence          String?
  session             String?
  entryPrice          Float
  stopLoss            Float?
  takeProfit          Float?
  riskPercent         Float?
  lotSize             Float?
  rrRatio             Float?
  riskAmount          Float?
  status              String
  profitAmount        Float?
  preTradeNote        String?
  executionNote       String?
  mistakeNote         String?
  lessonNote          String?
  imageUrlBefore      String?
  imageUrlAfter       String?
  tags                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  voiceGeneratedNotes Boolean? @default(false)
  checklistData       Json?
  checklistScore      Int?
  checklistTotal      Int?
  account             Account  @relation(fields: [accountId], references: [id])
  setupRelation       Setup?   @relation(fields: [setupId], references: [id])
}
